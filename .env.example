# ── Backend env vars (set these in Railway dashboard) ────────────────────────

# Anthropic API key — required
ANTHROPIC_API_KEY=sk-ant-api03-...

# Allowed frontend origins — comma-separated, no trailing slash
# Set to your Vercel deployment URL
CORS_ORIGINS=https://your-app.vercel.app

# SQLite path — point to a Railway persistent volume
# In Railway: add a volume mounted at /data, then set DB_PATH=/data/trainer.db
DB_PATH=/data/trainer.db

# ── Frontend env vars (set these in Vercel dashboard) ────────────────────────

# Your Railway backend URL — no trailing slash
# VITE_API_URL=https://your-app.up.railway.app
