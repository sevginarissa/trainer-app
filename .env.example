# Copy to .env and fill in real values — never commit .env to git

# ── Anthropic (required) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio WhatsApp (required for WhatsApp integration) ───────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Database ─────────────────────────────────────────────────────────────────
# Override for production (e.g. /data/trainer.db on a mounted volume)
DB_PATH=db/trainer.db

# ── CORS (Railway/Vercel deployment) ─────────────────────────────────────────
# Comma-separated allowed origins. On Lightsail (same-origin), leave unset.
# CORS_ORIGINS=https://your-app.vercel.app

# ── Frontend (Vercel only) ────────────────────────────────────────────────────
# Your Railway backend URL — no trailing slash
# VITE_API_URL=https://your-app.up.railway.app
